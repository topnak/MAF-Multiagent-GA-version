        <mxCell id="workflows_list" value="Key Features:&#xa;• Type Safety - Strong typing for message flow&#xa;• Flexible Control Flow - Conditional routing&#xa;• External Integration - APIs &amp; HITL&#xa;• Checkpointing - Save/resume workflow states&#xa;• Multi-Agent Orchestration&#xa;&#xa;Core Concepts:&#xa;• Executors - Processing units (agents/functions)&#xa;• Edges - Connections with conditions&#xa;• Events - Lifecycle &amp; custom events&#xa;• Supersteps - Managed execution&#xa;• Streaming &amp; Non-streaming modes" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#333333;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="810" y="168" width="340" height="185" as="geometry" />
        </mxCell>
        
