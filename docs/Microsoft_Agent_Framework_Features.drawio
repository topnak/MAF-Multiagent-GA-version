        <mxCell id="orch_title" value="Multi-Agent Orchestration" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#283593;" vertex="1" parent="1">
          <mxGeometry x="1190" y="145" width="200" height="20" as="geometry" />
