        <mxCell id="workflows_title" value="Graph-Based Workflow Engine" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#0D47A1;" vertex="1" parent="1">
