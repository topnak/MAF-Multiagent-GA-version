# ─────────────────────────────────────────────────────────────────────────────
# MAF 1.0 GA Multi-Agent POC — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# SECURITY WARNING: Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
# ─────────────────────────────────────────────────────────────────────────────

# ═══════════════════════════════════════════════════════════════════════════════
# AZURE IDENTITY (EntraID / Azure Active Directory)
# ═══════════════════════════════════════════════════════════════════════════════
# Required for EntraID authentication
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here

# ═══════════════════════════════════════════════════════════════════════════════
# LLM PROVIDER SELECTION
# ═══════════════════════════════════════════════════════════════════════════════
# Options: foundry, openai, anthropic, gemini, ollama, bedrock
# Default: foundry (Azure OpenAI via Foundry)
AGENT_PROVIDER=foundry

# ─── Azure OpenAI (when AGENT_PROVIDER=foundry) ───
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21

# ─── OpenAI Direct (when AGENT_PROVIDER=openai) ───
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# ─── Anthropic Claude (when AGENT_PROVIDER=anthropic) ───
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── Google Gemini (when AGENT_PROVIDER=gemini) ───
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# ─── Local Ollama (when AGENT_PROVIDER=ollama) ───
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ─── AWS Bedrock (when AGENT_PROVIDER=bedrock) ───
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-here
AWS_SECRET_ACCESS_KEY=your-aws-secret-key-here
BEDROCK_MODEL=anthropic.claude-3-sonnet-20240229-v1:0

# ═══════════════════════════════════════════════════════════════════════════════
# MEMORY & STORAGE
# ═══════════════════════════════════════════════════════════════════════════════
# Redis for chat history and semantic caching
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Azure Cosmos DB for checkpoints (optional, file-based fallback available)
COSMOS_CONNECTION_STRING=
COSMOS_DATABASE=multiagent
COSMOS_CONTAINER=checkpoints

# ═══════════════════════════════════════════════════════════════════════════════
# OBSERVABILITY
# ═══════════════════════════════════════════════════════════════════════════════
# OpenTelemetry collector endpoint
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=maf-multiagent-poc

# Langfuse (optional - for LLM observability)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ═══════════════════════════════════════════════════════════════════════════════
# APPLICATION SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════
# Environment: development, staging, production
ENVIRONMENT=development

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# API settings
API_HOST=0.0.0.0
API_PORT=8000

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ═══════════════════════════════════════════════════════════════════════════════
# MCP SERVER URLS (Mock servers for POC)
# ═══════════════════════════════════════════════════════════════════════════════
MCP_SNOWFLAKE_URL=http://localhost:8081
MCP_PERSONALISATION_URL=http://localhost:8082
MCP_LOCALISATION_URL=http://localhost:8083
MCP_ITEMS_API_URL=http://localhost:8084
MCP_SALESFORCE_URL=http://localhost:8085
MCP_WEATHER_URL=http://localhost:8086

# ═══════════════════════════════════════════════════════════════════════════════
# A2A AGENT ENDPOINTS (Mock for POC)
# ═══════════════════════════════════════════════════════════════════════════════
A2A_SNOWFLAKE_CORTEX_URL=http://localhost:9001
A2A_VERTEX_AI_URL=http://localhost:9002
A2A_SALESFORCE_AGENTFORCE_URL=http://localhost:9003
